#!/bin/bash
set -e

DOTFILES="$HOME/.dotfiles"

bold() { tput bold; echo "$1"; tput sgr0; }
warn() { tput setaf 3; echo "$1"; tput sgr0; }
sep()  { echo "-------------------"; }

ask() {
	read -rp "$1 (y/n) " answer
	[[ "$answer" == "y" ]]
}

# --- Xcode CLI Tools ---
if ! xcode-select -p &>/dev/null; then
	bold "Installing Xcode Command Line Tools..."
	xcode-select --install
	echo "Press enter once the installation is complete."
	read -r
else
	warn "Xcode CLI tools already installed"
fi

# --- Homebrew ---
sep
if ! command -v brew &>/dev/null; then
	bold "Installing Homebrew..."
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	eval "$(/opt/homebrew/bin/brew shellenv)"
else
	warn "Homebrew already installed"
fi

# --- Brew Bundle ---
sep
bold "Installing apps via Homebrew..."
brew update
brew bundle install --file="$DOTFILES/Brewfile"

# --- Fish Shell ---
sep
source "$DOTFILES/setup.d/fish.sh"

# --- Ghostty ---
sep
source "$DOTFILES/setup.d/ghostty.sh"

# --- Git ---
sep
source "$DOTFILES/setup.d/git.sh"

# --- Mise ---
sep
source "$DOTFILES/setup.d/mise.sh"

# --- SSH via 1Password ---
sep
source "$DOTFILES/setup.d/1password.sh"

# --- macOS ---
sep
source "$DOTFILES/setup.d/macos.sh"

# --- Finish ---
sep
bold "All done!"
